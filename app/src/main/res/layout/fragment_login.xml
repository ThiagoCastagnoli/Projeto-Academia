<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/login_page"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bckgrd"
    android:orientation="vertical">


    <ImageView

        android:layout_width="wrap_content"
        android:layout_height="66dp"
        android:layout_marginTop="10dp"
        android:src="@drawable/cardio_workout_icon_150073" />

    <TextView
        android:id="@+id/textView4"
        android:layout_marginHorizontal="40dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="1dp"
        android:text="Faça Seu Login"
        android:textColor="@color/black"
        android:textSize="25dp"
        android:textStyle="bold" />


    <EditText
        android:id="@+id/edit_text_emaillogin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="10dp"
        android:layout_marginTop="150dp"
        android:layout_marginRight="10dp"
        android:ems="10"
        android:hint="Email" />

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <EditText
        android:id="@+id/editText_senhalogin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ems="10"
        android:inputType="textPassword"
        android:layout_margin="10dp"
        android:hint="senha"
        />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="20dp"
        android:text="salvar login"
        android:textSize="15dp" />


    <Switch
        android:id="@+id/savelogin"
        android:layout_width="78dp"
        android:layout_height="16dp"
        android:layout_marginRight="340dp" />

<Button
    android:background="@color/black"
    android:id="@+id/button_login"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:text="Entrar"
    android:textColor="@color/white"
    android:layout_marginHorizontal="40dp"

    />

    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="40dp"
        android:visibility="gone" />
    <Button
        android:id="@+id/button_cadastro"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="40dp"
        android:text="Cadastre-se" />

    <ImageView

        android:id="@+id/imageView2"
        android:layout_width="match_parent"
        android:layout_height="150dp"
        android:padding="25dp"
        android:layout_marginHorizontal="40dp"
        android:src="@drawable/treino" />


</LinearLayout>